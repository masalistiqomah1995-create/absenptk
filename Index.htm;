<!DOCTYPE html>
<html>
<head>
  <base target="_top">
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="manifest" href='data:application/json,{"short_name":"Absen MA","name":"ABSENSI KEHADIRAN GURU MA AL ISTIQOMAH","icons":[{"src":"https://masalistiqomah.sch.id/wp-content/uploads/2026/05/logo-e1492233052256.png","type":"image/png","sizes":"192x192"}],"start_url":"?","background_color":"#0d6efd","display":"standalone","theme_color":"#0d6efd"}'>
  
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  
  <style>
    body { background-color: #f8f9fa; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
    .navbar-brand img { height: 40px; width: auto; margin-right: 10px; }
    .card-stat { background: #fff; border-left: 5px solid #0d6efd; border-radius: 8px; }
    
    /* Print Setting: F5 Portrait Paper layout (165mm x 215mm) with standard margin 15mm */
    @page { 
      size: 165mm 215mm portrait; 
      margin: 15mm; 
    }
    
    @media print {
      body { background: white; font-size: 10pt; color: #000; }
      .no-print { display: none !important; }
      
      /* Kop surat cetak sejajar */
      .print-header { display: flex !important; align-items: center; justify-content: flex-start; border-bottom: 3px double #000; padding-bottom: 10px; margin-bottom: 15px; width: 100%; }
      .print-header img { width: 65px; height: 65px; margin-right: 15px; object-fit: contain; }
      .print-header-text { text-align: center; flex-grow: 1; }
      .print-title { font-size: 12pt; font-weight: bold; margin-bottom: 2px; }
      .print-subtitle { font-size: 14pt; font-weight: bold; margin-bottom: 2px; }
      .print-address { font-size: 7.5pt; margin-bottom: 0; }
      .print-contact { font-size: 7pt; font-style: italic; }
      
      .table { border-color: #000 !important; width: 100% !important; }
      .table th, .table td { padding: 4px 6px; font-size: 9.5pt; }
    }
    
    .print-header { display: none; }
  </style>
</head>
<body>

  <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm no-print">
    <div class="container">
      <a class="navbar-brand d-flex align-items-center" href="#">
        <img src="https://masalistiqomah.sch.id/wp-content/uploads/2026/05/logo-e1492233052256.png" alt="Logo">
        <span>ABSENSI KEHADIRAN GURU MA AL ISTIQOMAH</span>
      </a>
      <div class="ms-auto" id="navAction"></div>
    </div>
  </nav>

  <div class="container mt-4">
    <div id="page-login" class="row justify-content-center">
      <div class="col-md-5">
        <div class="card shadow-sm">
          <div class="card-body p-4 text-center">
            <img src="https://masalistiqomah.sch.id/wp-content/uploads/2026/05/logo-e1492233052256.png" alt="Logo" style="width: 80px;" class="mb-3">
            <h4 class="card-title mb-4">Login Absensi Guru</h4>
            <div id="loginAlert" class="alert alert-danger d-none"></div>
            <form id="formLogin" onsubmit="handleLogin(event)">
              <div class="input-group mb-3">
                <span class="input-group-text"><i class="fa-solid fa-user"></i></span>
                <input type="text" class="form-control" id="username" placeholder="Username" required>
              </div>
              <div class="input-group mb-3">
                <span class="input-group-text"><i class="fa-solid fa-lock"></i></span>
                <input type="password" class="form-control" id="password" placeholder="Password" required>
              </div>
              <button type="submit" class="btn btn-primary w-100"><i class="fa-solid fa-right-to-bracket me-2"></i> Masuk</button>
            </form>
          </div>
        </div>
        
        <div class="alert alert-info py-2 px-2 mt-3 fw-bold small text-center shadow-sm">
          <marquee behavior="scroll" direction="left">Jangan Lupa Absen kehadiran, Masuk 06.00 – 08.00 dan Absen Pulang 13.00 – 20.00</marquee>
        </div>
      </div>
    </div>

    <div id="page-home" class="d-none">
      <div class="jumbotron p-5 mb-4 bg-white rounded-3 shadow-sm text-center">
        <img src="https://masalistiqomah.sch.id/wp-content/uploads/2026/05/logo-e1492233052256.png" alt="Logo" style="width: 100px;" class="mb-3">
        <h2 class="display-5 fw-bold">Absensi Kehadiran Guru</h2>
        <p class="fs-4">Madrasah Aliyah Al Istiqomah</p>
        <hr class="my-4">
        <div class="row justify-content-center mt-4">
          <div class="col-md-4">
            <div class="card p-3 card-stat">
              <div class="card-body">
                <h5 class="card-title text-muted">Guru Hadir Hari Ini</h5>
                <h3 class="display-4 fw-bold" id="stat-hadir">0</h3>
              </div>
            </div>
          </div>
        </div>
        <button class="btn btn-success btn-lg mt-4" onclick="switchPage('page-login')"><i class="fa-solid fa-right-to-bracket me-2"></i> Akses Halaman Login</button>
      </div>
    </div>

    <div id="page-admin" class="d-none">
      <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom no-print">
        <h1 class="h2">Dashboard Admin</h1>
        <button class="btn btn-outline-danger btn-sm" onclick="logout()"><i class="fa-solid fa-power-off me-1"></i> Keluar</button>
      </div>
      
      <ul class="nav nav-tabs no-print" id="adminTab" role="tablist">
        <li class="nav-item" role="presentation">
          <button class="nav-link active" id="grafik-tab" data-bs-toggle="tab" data-bs-target="#grafik-pane" type="button" role="tab"><i class="fa-solid fa-chart-pie me-1"></i> Grafik</button>
        </li>
        <li class="nav-item" role="presentation">
          <button class="nav-link" id="data-tab" data-bs-toggle="tab" data-bs-target="#data-pane" type="button" role="tab"><i class="fa-solid fa-users me-1"></i> Data Guru</button>
        </li>
        <li class="nav-item" role="presentation">
          <button class="nav-link" id="rekap-tab" data-bs-toggle="tab" data-bs-target="#rekap-pane" type="button" role="tab"><i class="fa-solid fa-print me-1"></i> Rekap & Cetak</button>
        </li>
        <li class="nav-item" role="presentation">
          <button class="nav-link" id="setting-tab" data-bs-toggle="tab" data-bs-target="#setting-pane" type="button" role="tab"><i class="fa-solid fa-gear me-1"></i> Pengaturan</button>
        </li>
      </ul>
      
      <div class="tab-content p-4 bg-white border border-top-0 rounded-bottom" id="adminTabContent">
        <div class="tab-pane fade show active" id="grafik-pane" role="tabpanel">
          <h5>Grafik Rekapitulasi Kehadiran Harian</h5>
          <div class="row mt-4 justify-content-center">
            <div class="col-md-8">
              <div class="card shadow-sm p-3">
                <canvas id="attendanceChart" height="120"></canvas>
              </div>
            </div>
          </div>
        </div>

        <div class="tab-pane fade" id="data-pane" role="tabpanel">
          <h5>Data Guru Madrasah</h5>
          <div class="table-responsive mt-3">
            <table class="table table-striped table-bordered">
              <thead>
                <tr>
                  <th>ID</th>
                  <th>Nama Guru</th>
                </tr>
              </thead>
              <tbody id="table-teachers"></tbody>
            </table>
          </div>
          <hr>
          <h6>Tambah Guru Baru</h6>
          <form id="formAddTeacher" class="row g-3" onsubmit="handleAddTeacher(event)">
            <div class="col-auto">
              <input type="text" class="form-control" id="teacherId" placeholder="ID Guru (NIP/NUPTK)" required>
            </div>
            <div class="col-auto">
              <input type="text" class="form-control" id="teacherName" placeholder="Nama Lengkap" required>
            </div>
            <div class="col-auto">
              <button type="submit" class="btn btn-success"><i class="fa-solid fa-plus"></i> Simpan</button>
            </div>
          </form>
        </div>

        <div class="tab-pane fade" id="rekap-pane" role="tabpanel">
          <h5 class="no-print">Print & Unduh Rekap Absensi</h5>
          <div class="row g-3 align-items-center mt-2 mb-3 no-print">
            <div class="col-auto">
              <label class="col-form-label">Pilih Tanggal:</label>
            </div>
            <div class="col-auto">
              <input type="date" id="rekapDate" class="form-control">
            </div>
            <div class="col-auto">
              <button class="btn btn-primary" onclick="loadRecapData()"><i class="fa-solid fa-magnifying-glass me-1"></i> Tampilkan</button>
            </div>
            <div class="col-auto">
              <button class="btn btn-success" onclick="window.print()"><i class="fa-solid fa-print me-1"></i> Cetak (F5)</button>
            </div>
          </div>
          
          <div class="print-header">
            <img src="https://masalistiqomah.sch.id/wp-content/uploads/2026/05/logo-e1492233052256.png" alt="Logo Madrasah">
            <div class="print-header-text">
              <div class="print-title">YAYASAN HUDAATUL UMAM</div>
              <div class="print-subtitle">MADRASAH ALIYAH AL ISTIQOMAH</div>
              <div class="print-address">Jl. Kawasan No. 63 Pasir Awi Suka Asih Pasar Kemis Kab. Tangerang – Banten 15560</div>
              <div class="print-contact">Website : https://masalistiqomah.sch.id &nbsp; email : masalistiqomah1995@gmail.com</div>
            </div>
          </div>

          <h5 class="text-center mb-3 fw-bold d-none d-print-block">REKAPITULASI KEHADIRAN GURU</h5>

          <div class="table-responsive">
            <table class="table table-bordered">
              <thead>
                <tr>
                  <th>Tanggal & Waktu</th>
                  <th>Nama Guru</th>
                  <th>Status</th>
                  <th>Keterangan</th>
                </tr>
              </thead>
              <tbody id="table-rekap-admin"></tbody>
            </table>
          </div>
        </div>

        <div class="tab-pane fade" id="setting-pane" role="tabpanel">
          <h5>Tahun Pelajaran</h5>
          <div class="input-group mb-3 w-50 mt-3">
            <span class="input-group-text">Tahun Ajaran</span>
            <input type="text" class="form-control" id="academicYearInput" placeholder="Contoh: 2026/2027">
            <button class="btn btn-outline-primary" onclick="saveAcademicYear()">Simpan</button>
          </div>
          <hr>
          <h5>Manajemen Username (Login)</h5>
          <p class="text-muted">Kelola data login pada tab sheet <code>user</code> di Google Spreadsheet Anda langsung.</p>
        </div>
      </div>
    </div>

    <div id="page-guru" class="d-none">
      <div class="d-flex justify-content-between align-items-center pt-3 pb-2 mb-3 border-bottom">
        <h1 class="h2">Panel Kehadiran - <span id="guru-name-title"></span></h1>
        <button class="btn btn-outline-danger btn-sm" onclick="logout()"><i class="fa-solid fa-power-off me-1"></i> Keluar</button>
      </div>

      <div class="row">
        <div class="col-md-5 mb-4">
          <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">Input Absen Mandiri</div>
            <div class="card-body">
              <div id="absenAlert" class="alert d-none"></div>
              <form id="formAbsen" onsubmit="handleAbsen(event)">
                <div class="mb-3">
                  <label class="form-label">Jenis Absen</label>
                  <select class="form-select" id="absenJenis" required>
                    <option value="" selected disabled>Pilih Sesi Absen...</option>
                    <option value="Masuk">Absen Masuk (06.00 - 08.00)</option>
                    <option value="Pulang">Absen Pulang (13.00 - 23.00)</option>
                  </select>
                </div>
                <div class="mb-3">
                  <label class="form-label">Status Kehadiran</label>
                  <select class="form-select" id="absenStatus" required>
                    <option value="" selected disabled>Pilih Status...</option>
                    <option value="Hadir">Hadir</option>
                    <option value="Sakit">Sakit</option>
                    <option value="Izin">Izin</option>
                    <option value="Dinas Luar">Dinas Luar</option>
                  </select>
                </div>
                <button type="submit" class="btn btn-primary w-100"><i class="fa-solid fa-paper-plane me-2"></i> Kirim Absen</button>
              </form>
            </div>
          </div>
        </div>

        <div class="col-md-7">
          <div class="card shadow-sm">
            <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
              <span>Rekap Absen Anda Bulan Ini</span>
              <input type="month" id="rekapMonthGuru" class="form-control form-control-sm w-auto" onchange="loadRecapGuru()">
            </div>
            <div class="card-body">
              <div class="table-responsive">
                <table class="table table-striped table-sm">
                  <thead>
                    <tr>
                      <th>Tanggal</th>
                      <th>Status</th>
                      <th>Keterangan</th>
                    </tr>
                  </thead>
                  <tbody id="table-rekap-guru"></tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    let currentUser = null;
    let currentRole = null;
    let currentName = null;
    let myChart = null;

    window.onload = function() {
      google.script.run.withSuccessHandler(function(data) {
        document.getElementById('stat-hadir').innerText = data.hadir;
      }).getStats();
      
      let now = new Date();
      let day = ("0" + now.getDate()).slice(-2);
      let month = ("0" + (now.getMonth() + 1)).slice(-2);
      let year = now.getFullYear();
      
      document.getElementById('rekapDate').value = `${year}-${month}-${day}`;
      document.getElementById('rekapMonthGuru').value = `${year}-${month}`;

      initChart();
    };

    function initChart() {
      const ctx = document.getElementById('attendanceChart').getContext('2d');
      myChart = new Chart(ctx, {
        type: 'bar',
        data: {
          labels: ['Hadir', 'Sakit', 'Izin', 'Dinas Luar'],
          datasets: [{
            label: 'Jumlah Guru',
            data: [0, 0, 0, 0],
            backgroundColor: ['#198754', '#ffc107', '#0dcaf0', '#0d6efd'],
            borderWidth: 1
          }]
        },
        options: {
          responsive: true,
          scales: {
            y: {
              beginAtZero: true,
              ticks: { stepSize: 1 }
            }
          },
          plugins: {
            title: {
              display: false
            }
          }
        }
      });
    }

    function updateChart(data) {
      let hadir = 0, sakit = 0, izin = 0, dinas = 0;
      data.forEach(row => {
        if (row.status.includes('Hadir')) hadir++;
        else if (row.status.includes('Sakit')) sakit++;
        else if (row.status.includes('Izin')) izin++;
        else if (row.status.includes('Dinas Luar')) dinas++;
      });
      myChart.data.datasets[0].data = [hadir, sakit, izin, dinas];
      myChart.update();
    }

    function switchPage(pageId) {
      document.getElementById('page-login').classList.add('d-none');
      document.getElementById('page-home').classList.add('d-none');
      document.getElementById('page-admin').classList.add('d-none');
      document.getElementById('page-guru').classList.add('d-none');
      document.getElementById(pageId).classList.remove('d-none');
    }

    function handleLogin(e) {
      e.preventDefault();
      const user = document.getElementById('username').value;
      const pass = document.getElementById('password').value;
      const alertBox = document.getElementById('loginAlert');
      
      google.script.run.withSuccessHandler(function(res) {
        if(res.status) {
          currentUser = res.username; 
          currentRole = res.role;
          currentName = res.nama || res.name || res.username; 
          alertBox.classList.add('d-none');
          
          if(currentRole === 'Admin') {
            switchPage('page-admin');
            loadAdminData();
          } else {
            switchPage('page-guru');
            document.getElementById('guru-name-title').innerText = currentName;
            loadRecapGuru();
          }
        } else {
          alertBox.innerText = res.message;
          alertBox.classList.remove('d-none');
        }
      }).verifyLogin(user, pass);
    }

    function logout() {
      currentUser = null;
      currentRole = null;
      currentName = null;
      document.getElementById('username').value = '';
      document.getElementById('password').value = '';
      switchPage('page-home');
    }

    function loadAdminData() {
      google.script.run.withSuccessHandler(function(teachers) {
        let tbody = document.getElementById('table-teachers');
        tbody.innerHTML = '';
        teachers.forEach(t => {
          tbody.innerHTML += `<tr><td>${t.id}</td><td>${t.name}</td></tr>`;
        });
      }).getTeachers();
      
      google.script.run.withSuccessHandler(function(year) {
        document.getElementById('academicYearInput').value = year;
      }).getAcademicYear();
      
      loadRecapData();
    }

    function handleAddTeacher(e) {
      e.preventDefault();
      const id = document.getElementById('teacherId').value;
      const name = document.getElementById('teacherName').value;
      google.script.run.withSuccessHandler(function() {
        alert('Data guru berhasil ditambahkan!');
        document.getElementById('teacherId').value = '';
        document.getElementById('teacherName').value = '';
        loadAdminData();
      }).addTeacher(id, name);
    }

    function loadRecapData() {
      const selectedDate = document.getElementById('rekapDate').value;
      if(!selectedDate) return;
      
      google.script.run.withSuccessHandler(function(data) {
        let tbody = document.getElementById('table-rekap-admin');
        tbody.innerHTML = '';
        data.forEach(row => {
          tbody.innerHTML += `<tr><td>${row.tanggal}</td><td>${row.nama}</td><td>${row.status}</td><td>${row.keterangan}</td></tr>`;
        });
        updateChart(data);
      }).getRecap(selectedDate, "Semua");
    }

    function saveAcademicYear() {
      const year = document.getElementById('academicYearInput').value;
      google.script.run.withSuccessHandler(function() {
        alert('Tahun Pelajaran diperbarui.');
      }).updateAcademicYear(year);
    }

    function handleAbsen(e) {
      e.preventDefault();
      const jenis = document.getElementById('absenJenis').value;
      const status = document.getElementById('absenStatus').value;
      const alertBox = document.getElementById('absenAlert');
      
      const now = new Date();
      const currentHour = now.getHours();
      const currentMinute = now.getMinutes();
      const totalMinutes = (currentHour * 60) + currentMinute; 
      
      if (jenis === 'Masuk' && (totalMinutes < 360 || totalMinutes > 480)) {
        alertBox.innerText = "Gagal: Absen Masuk hanya dapat dilakukan pada pukul 06.00 – 08.00.";
        alertBox.className = "alert alert-danger mt-2";
        alertBox.classList.remove('d-none');
        return;
      }
      
      if (jenis === 'Pulang' && (totalMinutes < 780 || totalMinutes > 1380)) {
        alertBox.innerText = "Gagal: Absen Pulang hanya dapat dilakukan pada pukul 13.00 – 23.00.";
        alertBox.className = "alert alert-danger mt-2";
        alertBox.classList.remove('d-none');
        return;
      }

      const fullStatus = `${status} (${jenis})`;
      
      google.script.run.withSuccessHandler(function(res) {
        alertBox.innerText = res.message;
        alertBox.className = "alert mt-2 " + (res.success ? "alert-success" : "alert-danger");
        alertBox.classList.remove('d-none');
        if(res.success) loadRecapGuru();
      }).submitAttendance(currentUser, fullStatus);
    }

    function loadRecapGuru() {
      const monthYear = document.getElementById('rekapMonthGuru').value;
      google.script.run.withSuccessHandler(function(data) {
        let tbody = document.getElementById('table-rekap-guru');
        tbody.innerHTML = '';
        data.forEach(row => {
          tbody.innerHTML += `<tr><td>${row.tanggal}</td><td>${row.status}</td><td>${row.keterangan}</td></tr>`;
        });
      }).getRecap(monthYear, currentUser);
    }
  </script>
</body>
</html>